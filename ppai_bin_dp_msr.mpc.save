import math
from Compiler import ml
from Compiler.library import vectorize, for_range, for_range_opt

# OPTIMIZATION: Precision
# f=16 (fractional), k=33 (total).
# Integer bits = 33 - 16 = 17 bits (Range +/- 65,536).
# Fits '22264' comfortably.
sfix.set_precision(16, 33)

############# Getting secret shares #############

num_patients_0 = int(program.args[1]) 
num_patients_1 = int(program.args[2]) 
num_genes = int(program.args[3])      
num_classes = int(program.args[4])    
sigma = sfix(program.args[5])
sigma_bin_val = sfix(program.args[6])

target_delta = 1e-5
qtls = [0.25, 0.5, 0.75]

data_0 = sfix.Matrix(num_patients_0, num_genes+1)
data_1 = sfix.Matrix(num_patients_1, num_genes+1)
N = num_patients_0 + num_patients_1

data_0.input_from(0)
data_1.input_from(1)

############# Combined data & Transpose Trick #############
print_ln('Transposing data...')

train_data_T = sfix.Matrix(num_genes, N)
train_labels = sfix.Array(N)

# Using @for_range_opt to keep compilation fast
@for_range_opt(num_patients_0)
def _(i):
    @for_range_opt(num_genes)
    def _(j):
        train_data_T[j][i] = data_0[i][j]
    train_labels[i] = data_0[i][num_genes]

@for_range_opt(num_patients_1)
def _(i):
    idx = i + num_patients_0
    @for_range_opt(num_genes)
    def _(j):
        train_data_T[j][idx] = data_1[i][j]
    train_labels[idx] = data_1[i][num_genes]

############# Vectorized Helpers #############
@vectorize
def get_gaussian_value():
    sum_u = sfix(0)
    for _ in range(12):
        sum_u += sfix.get_random(0, 1)
    return sum_u - 6

def bin_column_vectorized(gene_col, n):
    # gene_col is expected to be a vector here
    gene1_q = Array.create_from(gene_col)
    gene1_q.sort()

    Q = sfix.Array(len(qtls))
    k = 0
    for q in qtls:
        pos = (n-1)*q
        floor_p = math.floor(pos)
        f = pos - floor_p
        if pos < 1:
            Q[k] = gene1_q[0]
        elif pos >= n:
            Q[k] = gene1_q[n]
        else:
            Q[k] = gene1_q[floor_p] + f * (gene1_q[floor_p+1] - gene1_q[floor_p])
        k = k+1

    # Vectorized comparisons
    c0 = (gene_col < Q[0])
    c1 = (gene_col < Q[1])
    c2 = (gene_col < Q[2])
    binned_gene = 3 - c2 - c1 - c0

    mean = sfix.Array(4)

    # Generate noise as vector, but access by constant index [b] is fine
    noise_array = get_gaussian_value(size=4)
    
    # Optimization: Multiplication
    sigma_bin_val = sfix(sigma_bin_int) * 0.0001

    for b in range(4):
        c_vec = (binned_gene == b)
        exact_count = sum(c_vec)
        exact_sum = sum(c_vec * gene_col)
        
        safe_count = exact_count + (exact_count == 0)
        exact_mean = exact_sum / safe_count
        mean[b] = exact_mean + (sigma_bin_val * noise_array[b])

    return binned_gene, mean

############# STEP 1: BINNING (SECRET) #############
start_timer(200)
print_ln('Starting secure binning...')

mean_matrix = sfix.Matrix(num_genes, 4)

@for_range_opt(num_genes)
def _(j):
    # .get_vector() loads the row from memory to register for fast SIMD
    gene_col = train_data_T[j].get_vector()
    
    binned_col, mean1 = bin_column_vectorized(gene_col, N)
    
    for b in range(4):
        mean_matrix[j][b] = mean1[b]
        
    # Write back
    train_data_T[j] = binned_col

stop_timer(200)
print_ln('Binning complete')

############# STEP 2: COMPUTE MARGINALS ON BINNED DATA (SECRET) #############
start_timer(300)
print_ln('Computing marginals on binned data...')

real_counts = sfix.Matrix(num_genes, 4)
real_counts_l = sfix.Array(num_classes)
real_counts_2way = sfix.Matrix(num_genes, 4 * num_classes)

# Store label vectors in Matrix for easy row access
label_is_vecs = sfix.Matrix(num_classes, N)

# Pre-compute label vectors
# Load train_labels to vector first for fast comparison
train_labels_vec = train_labels.get_vector()

@for_range(num_classes)
def _(l):
    l_vec = (train_labels_vec == l)
    label_is_vecs[l] = l_vec
    real_counts_l[l] = sum(l_vec)

# Compute marginals
@for_range_opt(num_genes)
def _(j):
    # Load row as vector
    val_r = train_data_T[j].get_vector()

    r_minus_10 = 1 - val_r
    r_minus_1 = val_r - 1
    r_minus_20 = 2 - val_r
    r_minus_2 = val_r - 2
    r_minus_30 = 3 - val_r
    
    # Vectorized indicator calculations
    ind_0 = (r_minus_10 * r_minus_20 * r_minus_30) / 6
    ind_1 = (val_r * r_minus_20 * r_minus_30) / 2
    ind_2 = (val_r * r_minus_1 * r_minus_30) / 2
    ind_3 = (val_r * r_minus_1 * r_minus_2) / 6
    
    # Store these temporarily. They are vectors (registers).
    gene_is_vecs = [ind_0, ind_1, ind_2, ind_3]

    for f in range(4):
        real_counts[j][f] = sum(gene_is_vecs[f])
        feat_idx = f * num_classes
        
        for c in range(num_classes):
            # label_is_vecs[c] is a MemValue (row), .get_vector() makes it a register
            # dot_product requires two registers (vectors)
            real_counts_2way[j][feat_idx + c] = sfix.dot_product(gene_is_vecs[f], label_is_vecs[c].get_vector())

stop_timer(300)

############# STEP 3: ADD NOISE (SECRET) #############
start_timer(400)
print_ln('Adding DP noise...')

sigma = sfix(sigma_int) * 0.0001

# FIX 1: Generate noise as vector, then wrap in Array.create_from()
# This allows 'noise_1way_features[idx]' to work with runtime index 'idx'
noise_1way_features_vec = get_gaussian_value(size=(num_genes * 4))
noise_1way_features = Array.create_from(noise_1way_features_vec)

noise_1way_labels_vec = get_gaussian_value(size=num_classes)
noise_1way_labels = Array.create_from(noise_1way_labels_vec)

@for_range_opt(num_genes)
def _(i):
    for j in range(4):
        idx = (i * 4) + j
        real_counts[i][j] = real_counts[i][j] + (sigma * noise_1way_features[idx])

@for_range_opt(num_classes)
def _(i):
    real_counts_l[i] = real_counts_l[i] + (sigma * noise_1way_labels[i])

# 2-way marginals noise
if target_delta == 0:
    sigma_2way = 1.0 / num_genes / 2.0
else:
    sigma_2way = sigma

total_2way_elements = num_genes * 4 * num_classes

# FIX 2: Wrap 2-way noise in Array too
noise_2way_vec = get_gaussian_value(size=total_2way_elements)
noise_2way = Array.create_from(noise_2way_vec)

@for_range_opt(num_genes)
def _(i):
    for k in range(4 * num_classes):
        idx = (i * 4 * num_classes) + k
        real_counts_2way[i][k] = real_counts_2way[i][k] + (sigma_2way * noise_2way[idx])

stop_timer(400)

############# STEP 4: REVEAL #############
start_timer(500)

print_ln('=== MARGINALS_OUTPUT_START ===')
print_ln('1WAY_FEATURES:')
@for_range(num_genes)
def _(i):
    for j in range(4):
        print_ln('%s', real_counts[i][j].reveal())

print_ln('1WAY_LABELS:')
@for_range(num_classes)
def _(i):
    print_ln('%s', real_counts_l[i].reveal())

print_ln('2WAY:')
@for_range(num_genes)
def _(i):
    for k in range(4 * num_classes):
        print_ln('%s', real_counts_2way[i][k].reveal())
print_ln('=== MARGINALS_OUTPUT_END ===')

print_ln('=== BIN_MEANS_START ===')
@for_range(num_genes)
def _(i):
    for j in range(4):
        print_ln('%s', mean_matrix[i][j].reveal())
print_ln('=== BIN_MEANS_END ===')

stop_timer(500)
print_ln('Complete!')
